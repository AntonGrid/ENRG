{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "lib": ["es2020"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "strict": false,
    "types": ["mocha", "chai", "node"]
  },
  "include": ["tests/**/*.ts"],
  "exclude": ["node_modules", "target"]
}
